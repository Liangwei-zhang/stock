# ══════════════════════════════════════════════════════════
# 環境變數範例 — 複製為 .env 後填入真實值
# 注意：.env 已加入 .gitignore，請勿提交至版本控制
# ══════════════════════════════════════════════════════════

# ─── 伺服器 port（前後端整合在同一服務）──────────────────
PORT=3000

# 寫入端點（/alerts POST、/db/ohlcv、/api/telegram）的鑑權金鑰
# 生產環境必須設定，建議使用 openssl rand -hex 32 產生
API_KEY=change_me_before_deploy

# Telegram 通知（在 https://t.me/BotFather 建立 Bot 后填入）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── 前端（Vite，需以 VITE_ 為前綴）────────────────────
# 與後端 API_KEY 相同（讓前端呼叫寫入端點時帶入 X-API-Key header）
VITE_API_KEY=change_me_before_deploy

# Polygon.io API Key（https://polygon.io/dashboard）
# 免費層：5 req/min，15 分鐘延遲
VITE_POLYGON_API_KEY=your_polygon_key_here

# ─── 注意 ────────────────────────────────────────────────
# 前後端已整合為單一服務，不再需要 VITE_SERVER_URL 和 API_URL
# 啟動方式：npm run dev（開發）或 npm run preview（生產）
