# ══════════════════════════════════════════════════════════
# 環境變數範例 — 複製為 .env 後填入真實值
# 注意：.env 已加入 .gitignore，請勿提交至版本控制
# 生成隨機密鑰：openssl rand -hex 32
# ══════════════════════════════════════════════════════════

# ─── 應用基礎 ────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_URL=https://yourdomain.com

# ─── 資料庫（透過 PgBouncer 連線）───────────────────────
DATABASE_URL=postgresql://stockuser:stockpass@pgbouncer:5432/stockdb
# Docker Compose 中的原始 PG（僅 migration 用）
# DATABASE_DIRECT_URL=postgresql://stockuser:stockpass@postgres:5432/stockdb

# ─── Redis ──────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── JWT（必填，至少 32 字元，用 openssl rand -hex 32 生成）──
JWT_SECRET=請替換為_openssl_rand_-hex_32_生成的隨機值
JWT_EXPIRES_IN=604800

# ─── 交易確認鏈接簽名密鑰（至少 16 字元）──────────────────
TRADE_LINK_SECRET=請替換為隨機值

# ─── 郵件服務（二選一，優先 Resend）────────────────────────
# Resend (推薦)
RESEND_API_KEY=
# Amazon SES（備用）
SES_REGION=us-east-1
SES_ACCESS_KEY=
SES_SECRET_KEY=

EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Stock Signal

# ─── CORS（生產必填，多個域名用逗號分隔）────────────────────
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ─── 監控端點 Bearer Token（/api/monitoring/）────────────
INTERNAL_TOKEN=請替換為隨機值

# ─── Polygon.io 行情 API（可選）─────────────────────────
POLYGON_API_KEY=

# ─── 前端（Vite，需以 VITE_ 為前綴）────────────────────
# 與後端 API_KEY 相同（讓前端呼叫寫入端點時帶入 X-API-Key header）
VITE_API_KEY=change_me_before_deploy

# Polygon.io API Key（https://polygon.io/dashboard）
# 免費層：5 req/min，15 分鐘延遲
VITE_POLYGON_API_KEY=your_polygon_key_here

# ─── 注意 ────────────────────────────────────────────────
# 前後端已整合為單一服務，不再需要 VITE_SERVER_URL 和 API_URL
# 啟動方式：npm run dev（開發）或 npm run preview（生產）
