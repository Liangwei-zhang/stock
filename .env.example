# ─── Telegram Bot 通知配置 ───────────────────────────────────────────────────
# 复制此文件为 .env，填入真实值，不要提交 .env 到 git

# 服务端环境变量（由 server.ts 读取，不暴露到浏览器端）
# Telegram 通知通过服务端中继发送，避免 CORS 封锁和 Token 泄露
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# [deprecated] 以下前端变量已弃用，服务端中继方案不再需要
# 保留仅供向后兼容，如有旧 .env 配置可安全移除
# VITE_TELEGRAM_BOT_TOKEN=your_bot_token_here
# VITE_TELEGRAM_CHAT_ID=your_chat_id_here
