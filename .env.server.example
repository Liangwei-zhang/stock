# ═══════════════════════════════════════════════════
# Stock 訂閱系統 — 環境變數配置範本
# 複製此文件為 .env 並填入實際值
# ═══════════════════════════════════════════════════

# ── 應用基礎 ──
NODE_ENV=development
PORT=3000
APP_NAME=stock
APP_URL=http://localhost:3000

# ── 資料庫（直連，開發用）──
DATABASE_URL=postgresql://stockuser:stockpass@localhost:5432/stockdb
# 生產環境透過 PgBouncer 連接：
# DATABASE_URL=postgresql://stockuser:stockpass@localhost:6432/stockdb

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── JWT ──
# 至少 32 字元強隨機字串（openssl rand -hex 32）
JWT_SECRET=CHANGE_ME_USE_openssl_rand_hex_32_at_least_32chars
# JWT 有效期（秒），預設 7 天
JWT_EXPIRES_IN=604800

# ── 交易確認連結簽名 ──
# 至少 16 字元（openssl rand -hex 16）
TRADE_LINK_SECRET=CHANGE_ME_16chars_minimum

# ── 郵件服務（Amazon SES）──
SES_REGION=us-east-1
SES_ACCESS_KEY=
SES_SECRET_KEY=
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Stock Signal

# ── 備用郵件服務（Resend，開發/測試用）──
RESEND_API_KEY=

# ── CORS ──
# 多個來源用逗號分隔
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── 資料庫 Docker（docker-compose 使用）──
DB_USER=stockuser
DB_PASSWORD=stockpass
DB_NAME=stockdb

# ── Telegram（保留原有功能）──
# TELEGRAM_TARGETS='[{"botToken":"","chatId":"","name":""}]'
