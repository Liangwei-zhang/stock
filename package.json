{
  "name": "stock-alert-system",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:server": "tsx server/api.ts",
    "dev:scanner": "tsx server/scanner/index.ts",
    "dev:email-worker": "tsx server/email-worker.ts",
    "build": "tsc && vite build",
    "preview": "NODE_ENV=production tsx server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev:vite-only": "vite",
    "server": "tsx server.ts",
    "start": "npm run dev",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop all",
    "pm2:logs": "pm2 logs"
  },
  "dependencies": {
    "@ant-design/icons": "^5.2.6",
    "@aws-sdk/client-ses": "^3.1019.0",
    "@polygon.io/client-js": "^8.2.0",
    "antd": "^5.12.0",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "eventsource": "^4.1.0",
    "express": "^4.18.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lightweight-charts": "^4.1.0",
    "pg": "^8.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "resend": "^6.9.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.2.0",
    "jsdom": "^29.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vitest": "^1.2.0"
  },
  "vitest": {
    "environment": "jsdom",
    "globals": true
  }
}
