# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=MyApp
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/myapp
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/myapp

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (added on top of localhost defaults)
CORS_ORIGINS=https://yourdomain.com

# ── File upload ───────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760   # 10 MB in bytes

# ── Internal bearer (monitoring endpoints) ────────────────────────────────────
# Leave empty to disable bearer auth on /api/monitoring/*
X_BEARER_TOKEN=

# ── S3 / Object Storage (optional) ───────────────────────────────────────────
S3_ENABLED=false
S3_ENDPOINT_URL=         # e.g. https://s3.amazonaws.com
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=myapp
S3_REGION=us-east-1
S3_PUBLIC_URL=           # CDN base URL if available
